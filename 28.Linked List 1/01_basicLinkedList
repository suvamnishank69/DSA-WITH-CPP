class Node{  // Node class to store data and pointer to next node
    public:
    
    int data;
    Node* next;
    // This stores the address of the next node.
    // [10 | next] ----> [20 | next]

        Node(int val) {  //Node(10)
            data = val;   //data = 10
            next = NULL;  //Initially the node is not connected to any other node. or No next node
        }

};

